# انسخ الملف ده باسم .env واملأ القيم (أو ضيفهم كـ Secrets في Replit)

# مطلوب لتوقيع جلسات الدخول (JWT) - غيّره لأي نص عشوائي طويل (32+ حرف)
JWT_SECRET=change-this-to-a-long-random-string

# مطلوب عشان تشتغل قراءة الفواتير بالذكاء الاصطناعي فعليًا
# احصل عليه من https://console.anthropic.com
ANTHROPIC_API_KEY=

# اختياري - الموديل المستخدم للقراءة (له قيمة افتراضية لو مش موجود)
ANTHROPIC_MODEL=claude-sonnet-5

# اختياري - البورت اللي السيرفر هيشتغل عليه محليًا
PORT=3000

# ==== البريد الإلكتروني (تأكيد الحساب + نسيت كلمة المرور) ====
# لو الحقول دي فاضية، روابط التأكيد/إعادة التعيين هتظهر في استجابة الـ API
# والـ console بدل ما تتبعت بريد فعلي (مفيد وقت التطوير، لازم تتظبط قبل الإطلاق الحقيقي).
# مثال باستخدام Gmail SMTP أو أي مزود زي SendGrid/Mailgun/Postmark:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=QuickSum AI <no-reply@quicksum.ai>

# رابط الموقع نفسه - يُستخدم في بناء روابط تأكيد البريد وإعادة تعيين كلمة المرور
APP_URL=http://localhost:3000

# اختياري - لو عايز تقفل CORS على دومين الواجهة الحقيقي بتاعك بدل ما يكون مفتوح للكل
ALLOWED_ORIGIN=

# اضبطها production وقت النشر الحقيقي (بتفعّل تحذير أمان لو JWT_SECRET ضعيف)
NODE_ENV=development

# ==== وصول مغلق (Invite-only) — "طلب انضمام" بدل تسجيل مباشر ====
# لو INVITE_ONLY=true: يتقفل التسجيل المباشر، والزوار بيبعتوا "طلب انضمام"
# من الواجهة، وإنت (كأدمن) توافق أو ترفض من لوحة /admin
INVITE_ONLY=false

# مفتاح سري بسيط لدخول لوحة الإدارة (/admin) — اختار نص عشوائي طويل
# من غيره، لوحة الإدارة مش هتشتغل خالص
ADMIN_KEY=
